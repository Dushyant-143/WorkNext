# ===========================
# WorkNext — Environment Setup
# ===========================

# Django Secret Key — use a strong random key in production
SECRET_KEY=your-secret-key-here-change-this

# Debug — True for development, False for production
DEBUG=True

# Allowed Hosts — add your domain in production
# Example: ALLOWED_HOSTS=worknext.onrender.com,api.worknext.com
ALLOWED_HOSTS=*

# ===========================
# Database — PostgreSQL
# (If not set, SQLite will be used automatically)
# ===========================
# DB_NAME=worknext_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# ===========================
# CORS — add your frontend URL in production
# Example: CORS_ALLOWED_ORIGINS=https://worknext.vercel.app
# ===========================
# CORS_ALLOWED_ORIGINS=http://localhost:5173